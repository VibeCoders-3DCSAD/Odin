// Note: (anomaly_evaluation_id, user_id) references anomaly_evaluations(id, user_id) ON DELETE CASCADE
// Note: (parent_alert_id, user_id) references alerts(id, user_id) ON DELETE SET NULL
// Note: (overspending_evaluation_id, user_id) references overspending_evaluations(id, user_id) ON DELETE CASCADE
Table alerts {
  id uuid [pk]
  user_id uuid [not null, ref: > profiles.user_id]
  category text [not null]
  source_type text [not null]
  severity text [not null]
  status text [not null]
  title text [not null]
  body text [not null]
  explanation text
  action_label text
  route_name text
  route_params json [not null]
  transaction_id uuid [ref: > transactions.id]
  subcategory_id uuid [ref: > subcategories.id]
  budget_id uuid [ref: > budgets.id]
  debt_account_id uuid [ref: > debt_accounts.id]
  savings_goal_id uuid [ref: > savings_goals.id]
  forecast_run_id uuid [ref: > forecast_runs.id]
  budget_recommendation_id uuid [ref: > budget_recommendations.id]
  anomaly_evaluation_id uuid [ref: > anomaly_evaluations.id]
  overspending_evaluation_id uuid [ref: > overspending_evaluations.id]
  duplicate_key text
  bundle_key text
  parent_alert_id uuid [ref: > alerts.id]
  triggered_at timestamp [not null]
  delivered_in_app_at timestamp
  delivered_push_at timestamp
  read_at timestamp
  acknowledged_at timestamp
  dismissed_at timestamp
  cleared_at timestamp
  expires_at timestamp
  remind_at timestamp
  metadata json [not null]

  indexes {
    (id, user_id) [unique]
  }
}

