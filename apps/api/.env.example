# Odin API — Environment Variables
# Copy this file to .env and fill in the values.

# Supabase project URL (required)
# Found in your Supabase dashboard under Settings > API > Project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous public key (required)
# Found in your Supabase dashboard under Settings > API > anon public
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Password reset redirect URL (optional, defaults to odin://auth/reset)
# AUTH_REDIRECT_URL=odin://auth/reset

# Server port (optional, defaults to 3001)
# PORT=3001

# Supabase service role key (required for cron operations)
# Found in your Supabase dashboard under Settings > API > service_role key
# SUPABASE_SERVICE_ROLE_KEY=

# Recurring engine cron secret (required for POST /api/recurring/run)
# Set this to a random string and use it as the x-cron-secret header.
# RECURRING_CRON_SECRET=
