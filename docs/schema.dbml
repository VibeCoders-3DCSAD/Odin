  linked_subcategory_id uuid [not null, ref: > subcategories.id]
  name text [not null]
  status text [not null]
  progress_state text [not null]
  target_amount_centavos bigint [not null]
  current_amount_centavos bigint [not null]
  target_date date [not null]
  priority_rank integer [not null]
  projected_completion_date date
  achieved_at timestamp
  archived_at timestamp
  deleted_at timestamp
  notes text
  created_at timestamp [not null]
  updated_at timestamp [not null]
  metadata json [not null]

  indexes {
    (id, user_id) [unique]
  }
}

Table savings_goal_allocation_preferences {
  user_id uuid [pk, ref: > profiles.user_id]
  strategy text [not null]
  planned_contribution_centavos bigint [not null]
  updated_at timestamp [not null]
  metadata json [not null]
}

// Note: (savings_goal_id, user_id) references savings_goals(id, user_id) ON DELETE CASCADE
// Note: (transaction_id, user_id) references transactions(id, user_id) ON DELETE SET NULL
// Note: (source_budget_id, user_id) references budgets(id, user_id) ON DELETE SET NULL
Table savings_goal_contributions {
  id uuid [pk]
  savings_goal_id uuid [not null, ref: > savings_goals.id]
  user_id uuid [not null, ref: > profiles.user_id]
  transaction_id uuid [ref: > transactions.id]
  source text [not null]
  source_budget_id uuid [ref: > budgets.id]
  contribution_date date [not null]
  amount_centavos bigint [not null]
  notes text
  created_at timestamp [not null]
  metadata json [not null]
}

// Note: (savings_goal_id, user_id) references savings_goals(id, user_id) ON DELETE CASCADE
Table savings_goal_progress_snapshots {
  id uuid [pk]
  savings_goal_id uuid [not null, ref: > savings_goals.id]
  user_id uuid [not null, ref: > profiles.user_id]
  snapshot_date date [not null]
  current_amount_centavos bigint [not null]
  progress_percent_bps integer
  projected_completion_date date
  progress_state text [not null]
  metadata json [not null]

  indexes {
    (savings_goal_id, snapshot_date) [unique]
  }
}

Table savings_goal_budget_allocations {
  id uuid [pk]
  budget_allocation_id uuid [not null, ref: > budget_allocations.id]
  savings_goal_id uuid [not null, ref: > savings_goals.id]
  allocation_strategy text [not null]
  allocated_amount_centavos bigint [not null]
  remaining_amount_snapshot_centavos bigint [not null]
  allocation_order integer [not null]
  explanation text
  metadata json [not null]

  indexes {
    (budget_allocation_id, savings_goal_id) [unique]
  }
}

// Note: (linked_account_id, user_id) references financial_accounts(id, user_id) ON DELETE SET NULL
Table debt_accounts {
  id uuid [pk]
  user_id uuid [not null, ref: > profiles.user_id]
  linked_account_id uuid [ref: > financial_accounts.id]
