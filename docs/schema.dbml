Table profiles {
  id uuid [pk]
  user_id uuid [not null, unique, ref: > auth.users.id]
  display_name text
  metro_manila_city text
  lifecycle_status text [not null]
  onboarding_completed_at timestamp
  last_active_at timestamp
  created_at timestamp [not null]
  updated_at timestamp [not null]
  deleted_at timestamp
  metadata json [not null]
}

Table user_privacy_settings {
  user_id uuid [pk, ref: > profiles.user_id]
  personalization_enabled boolean [not null]
  model_training_opt_in boolean [not null]
  research_evaluation_opt_in boolean [not null]
  notifications_opt_in boolean [not null]
  data_retention_days integer
  updated_at timestamp [not null]
  metadata json [not null]
}

Table user_consents {
  id uuid [pk]
  user_id uuid [not null, ref: > profiles.user_id]
  consent_kind text [not null]
  status text [not null]
  version text [not null]
  recorded_at timestamp [not null]
  effective_at timestamp [not null]
  withdrawn_at timestamp
  source text
  ip_address inet
  user_agent text
  metadata json [not null]
}

Table data_export_requests {
  id uuid [pk]
  user_id uuid [not null, ref: > profiles.user_id]
  status text [not null]
  requested_at timestamp [not null]
  processed_at timestamp
  expires_at timestamp
  export_storage_path text
  failure_reason text
  metadata json [not null]
}

Table account_deletion_requests {
  id uuid [pk]
  user_id uuid [not null, ref: > profiles.user_id]
  status text [not null]
  requested_at timestamp [not null]
  confirmed_at timestamp
  scheduled_delete_at timestamp
  completed_at timestamp
  cancelled_at timestamp
  reason text
  metadata json [not null]
}

Table metro_manila_localities {
  code text [pk]
  name text [not null, unique]
  is_city boolean [not null]
  sort_order integer [not null]
}

Table user_eligibility_profiles {
  user_id uuid [pk, ref: > profiles.user_id]
  date_of_birth date
  is_filipino boolean
  metro_manila_presence text
  metro_manila_locality_code text [ref: > metro_manila_localities.code]
  primary_employment_classification text
  primary_employment_other text
  eligibility_confirmed_at timestamp
  updated_at timestamp [not null]
  metadata json [not null]
}

// Note: (id, user_id) unique
Table onboarding_sessions {
  id uuid [pk]
  user_id uuid [not null, ref: > profiles.user_id]
  status text [not null]
  started_at timestamp [not null]
  submitted_at timestamp
  abandoned_at timestamp
  superseded_at timestamp
  current_step_key text
  raw_answers json [not null]
  review_snapshot json [not null]
  metadata json [not null]

  indexes {
    (id, user_id) [unique]
  }
}

Table onboarding_responses {
  id uuid [pk]
  onboarding_session_id uuid [not null, ref: > onboarding_sessions.id]
  question_key text [not null]
  answer json [not null]
  updated_at timestamp [not null]

  indexes {
    (onboarding_session_id, question_key) [unique]
  }
}

// Note: (onboarding_session_id, user_id) references onboarding_sessions(id, user_id) ON DELETE SET NULL
Table financial_profile_assessments {
  id uuid [pk]
  user_id uuid [not null, ref: > profiles.user_id]
  onboarding_session_id uuid [ref: > onboarding_sessions.id]
  status text [not null]
  assessment_method text [not null]
  requested_at timestamp [not null]
  assessed_at timestamp
  model_kind text [not null]
  model_version text
  proposed_profile_label text
  confidence_score decimal
  income_type text
  obligation_load_bps integer
  explanation_summary text
  input_snapshot json [not null]
  output_snapshot json [not null]
  failure_reason text
  metadata json [not null]

  indexes {
    (id, user_id) [unique]
  }
}

Table financial_profile_explanation_drivers {
  id uuid [pk]
  assessment_id uuid [not null, ref: > financial_profile_assessments.id]
  driver_key text [not null]
  driver_label text [not null]
  value_text text
  impact_label text
  explanation text [not null]
  sort_order integer [not null]
}

// Note: (assessment_id, user_id) references financial_profile_assessments(id, user_id) ON DELETE SET NULL
Table financial_profile_assignments {
  id uuid [pk]
  user_id uuid [not null, ref: > profiles.user_id]
  assessment_id uuid [ref: > financial_profile_assessments.id]
  profile_label text [not null]
  is_active boolean [not null]
  confirmation_required boolean [not null]
  effective_from timestamp [not null]
  effective_to timestamp
  confirmed_at timestamp
  rejected_at timestamp
  override_reason text
  explanation text [not null]
  created_at timestamp [not null]
  metadata json [not null]

  indexes {
    (id, user_id) [unique]
  }
}

// Note: (assessment_id, user_id) references financial_profile_assessments(id, user_id) ON DELETE SET NULL
// Note: (assignment_id, user_id) references financial_profile_assignments(id, user_id) ON DELETE SET NULL
Table financial_profile_events {
  id uuid [pk]
  user_id uuid [not null, ref: > profiles.user_id]
  assessment_id uuid [ref: > financial_profile_assessments.id]
  assignment_id uuid [ref: > financial_profile_assignments.id]
  action text [not null]
  created_at timestamp [not null]
  notes text
  payload json [not null]
}

// Note: (last_assessment_id, user_id) references financial_profile_assessments(id, user_id) ON DELETE SET NULL
Table financial_profile_reclassification_schedules {
  user_id uuid [pk, ref: > profiles.user_id]
  status text [not null]
  trigger_source text [not null]
  cadence_days integer [not null]
  last_checked_at timestamp
  last_reclassified_at timestamp
  next_due_at timestamp
  last_assessment_id uuid [ref: > financial_profile_assessments.id]
  failure_reason text
  created_at timestamp [not null]
  updated_at timestamp [not null]
  metadata json [not null]
}

Table category_groups {
  id uuid [pk]
  slug text [not null, unique]
  label text [not null]
  short_label text
  description text [not null]
  sort_order integer [not null]
  is_active boolean [not null]
  metadata json [not null]
}

Table categories {
  id uuid [pk]
  category_group_id uuid [not null, ref: > category_groups.id]
  user_id uuid [ref: > profiles.user_id]
  slug text [not null]
  label text [not null]
  short_label text
  description text [not null]
  is_system boolean [not null]
  is_filipino_context boolean [not null]
  sort_order integer [not null]
  is_active boolean [not null]
  metadata json [not null]

  indexes {
    (user_id, slug) [unique]
    (label, category_group_id) [unique]
    (user_id, label, category_group_id) [unique]
  }
}

Table subcategories {
  id uuid [pk]
  category_id uuid [ref: > categories.id]
  user_id uuid [ref: > profiles.user_id]
  slug text [not null]
  kind text [not null]
  label text [not null]
  short_label text
  description text [not null]
  is_system boolean [not null]
  is_filipino_context boolean [not null]
  is_protected_default boolean [not null]
  is_protected boolean [not null]
  sort_order integer [not null]
  is_active boolean [not null]
  metadata json [not null]
}

Table user_subcategory_restrictions {
  id uuid [pk]
  user_id uuid [not null, ref: > profiles.user_id]
  subcategory_id uuid [not null, ref: > subcategories.id]
  restriction_level text [not null]
  floor_amount_centavos bigint
  ceiling_amount_centavos bigint
  effective_from date [not null]
  effective_to date
  notes text
  created_at timestamp [not null]
  updated_at timestamp [not null]
  metadata json [not null]
}

Table user_category_restrictions {
  id uuid [pk]
  user_id uuid [not null, ref: > profiles.user_id]
  category_id uuid [not null, ref: > categories.id]
  restriction_level text [not null]
  floor_amount_centavos bigint
  ceiling_amount_centavos bigint
  effective_from date [not null]
  effective_to date
  notes text
  created_at timestamp [not null]
  updated_at timestamp [not null]
  metadata json [not null]
}

Table income_sources {
  id uuid [pk]
  user_id uuid [not null, ref: > profiles.user_id]
  name text [not null]
  income_type text [not null]
  frequency text [not null]
  expected_amount_centavos bigint
  min_amount_centavos bigint
  max_amount_centavos bigint
  payday_day_of_month integer
  payday_second_day_of_month integer
  payday_day_of_week integer
  next_expected_date date
  is_active boolean [not null]
  notes text
  created_at timestamp [not null]
  updated_at timestamp [not null]
  metadata json [not null]
}

// Note: (id, user_id) unique
Table financial_accounts {
  id uuid [pk]
  user_id uuid [not null, ref: > profiles.user_id]
  name text [not null]
  kind text [not null]
  status text [not null]
  opening_balance_centavos bigint [not null]
  current_balance_centavos bigint [not null]
  credit_limit_centavos bigint
  include_in_dashboard_balance boolean [not null]
  institution_name text
  opened_on date
  archived_at timestamp
  deleted_at timestamp
  sort_order integer [not null]
  created_at timestamp [not null]
  updated_at timestamp [not null]
  metadata json [not null]

  indexes {
    (id, user_id) [unique]
  }
}

// Note: (id, user_id) unique
Table transaction_templates {
  id uuid [pk]
  user_id uuid [not null, ref: > profiles.user_id]
  transaction_type text [not null]
  status text [not null]
  name text [not null]
  amount_centavos bigint
  subcategory_id uuid [ref: > subcategories.id]
  source_account_id uuid [ref: > financial_accounts.id]
  destination_account_id uuid [ref: > financial_accounts.id]
  merchant_name text
  counterparty_name text
  notes text
  use_count integer [not null]
  last_used_at timestamp
  created_at timestamp [not null]
  updated_at timestamp [not null]
  deleted_at timestamp
  metadata json [not null]

  indexes {
    (id, user_id) [unique]
  }
}

// Note: (source_account_id, user_id) references financial_accounts(id, user_id) ON DELETE CASCADE
// Note: (destination_account_id, user_id) references financial_accounts(id, user_id) ON DELETE CASCADE
Table recurring_transaction_templates {
  id uuid [pk]
  user_id uuid [not null, ref: > profiles.user_id]
  transaction_type text [not null]
  status text [not null]
  name text [not null]
  amount_centavos bigint [not null]
  subcategory_id uuid [ref: > subcategories.id]
  source_account_id uuid [ref: > financial_accounts.id]
  destination_account_id uuid [ref: > financial_accounts.id]
  frequency text [not null]
  interval_count integer [not null]
  day_of_month integer
  second_day_of_month integer
  day_of_week integer
  custom_rule json [not null]
  starts_on date [not null]
  ends_on date
  next_occurrence_date date
  last_generated_date date
  reminder_enabled boolean [not null]
  reminder_days_before integer [not null]
  notes text
  created_at timestamp [not null]
  updated_at timestamp [not null]
  stopped_at timestamp
  deleted_at timestamp
  metadata json [not null]

  indexes {
    (id, user_id) [unique]
  }
}

// Note: (recurring_template_id, user_id) references recurring_transaction_templates(id, user_id) ON DELETE SET NULL
Table financial_obligations {
  id uuid [pk]
  user_id uuid [not null, ref: > profiles.user_id]
  subcategory_id uuid [not null, ref: > subcategories.id]
  recurring_template_id uuid [ref: > recurring_transaction_templates.id]
  name text [not null]
  status text [not null]
  amount_centavos bigint [not null]
  frequency text [not null]
  due_day_of_month integer
  is_family_support boolean [not null]
  is_dependent_support boolean [not null]
  protected_by_default boolean [not null]
  starts_on date
  ends_on date
  notes text
  created_at timestamp [not null]
  updated_at timestamp [not null]
  metadata json [not null]
}

// Note: (source_account_id, user_id) references financial_accounts(id, user_id) ON DELETE CASCADE
// Note: (destination_account_id, user_id) references financial_accounts(id, user_id) ON DELETE CASCADE
// Note: (recurring_template_id, user_id) references recurring_transaction_templates(id, user_id) ON DELETE SET NULL
Table transactions {
  id uuid [pk]
  user_id uuid [not null, ref: > profiles.user_id]
  transaction_type text [not null]
  status text [not null]
  entry_source text [not null]
  transaction_date date [not null]
  posted_at timestamp
  amount_centavos bigint [not null]
  subcategory_id uuid [ref: > subcategories.id]
  source_account_id uuid [ref: > financial_accounts.id]
  destination_account_id uuid [ref: > financial_accounts.id]
  recurring_template_id uuid [ref: > recurring_transaction_templates.id]
  merchant_name text
  counterparty_name text
  notes text
  client_mutation_id text
  created_at timestamp [not null]
  updated_at timestamp [not null]
  deleted_at timestamp
  retain_until date
  metadata json [not null]

  indexes {
    (id, user_id) [unique]
  }
}

Table transaction_line_items {
  id uuid [pk]
  transaction_id uuid [not null, ref: > transactions.id]
  user_id uuid [not null, ref: > profiles.user_id]
  subcategory_id uuid [not null, ref: > subcategories.id]
  item_label text [not null]
  quantity decimal
  amount_centavos bigint [not null]
  notes text
  sort_order integer [not null]
  metadata json [not null]
}

// Note: (transaction_id, user_id) references transactions(id, user_id) ON DELETE CASCADE
Table transaction_events {
  id uuid [pk]
  transaction_id uuid [not null, ref: > transactions.id]
  user_id uuid [not null, ref: > profiles.user_id]
  action text [not null]
  created_at timestamp [not null]
  before_snapshot json
  after_snapshot json
  notes text
  metadata json [not null]
}

// Note: (synced_transaction_id, user_id) references transactions(id, user_id) ON DELETE SET NULL
Table transaction_drafts {
  id uuid [pk]
  user_id uuid [not null, ref: > profiles.user_id]
  client_draft_id text [not null]
  status text [not null]
  payload json [not null]
  captured_offline_at timestamp
  synced_transaction_id uuid [ref: > transactions.id]
  last_error text
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (user_id, client_draft_id) [unique]
  }
}

Table user_transaction_retention_settings {
  user_id uuid [pk, ref: > profiles.user_id]
  retention_days integer [not null]
  auto_archive_enabled boolean [not null]
  archive_after_days integer
  purge_after_days integer
  updated_at timestamp [not null]
  metadata json [not null]
}

// Note: (transaction_id, user_id) references transactions(id, user_id) ON DELETE CASCADE
Table transaction_retention_events {
  id uuid [pk]
  user_id uuid [not null, ref: > profiles.user_id]
  transaction_id uuid [not null, ref: > transactions.id]
  action text [not null]
  actioned_at timestamp [not null]
  retain_until date
  notes text
  metadata json [not null]
}

// Note: (recurring_template_id, user_id) references recurring_transaction_templates(id, user_id) ON DELETE CASCADE
// Note: (generated_transaction_id, user_id) references transactions(id, user_id) ON DELETE CASCADE
Table recurring_transaction_occurrences {
  id uuid [pk]
  recurring_template_id uuid [not null, ref: > recurring_transaction_templates.id]
  user_id uuid [not null, ref: > profiles.user_id]
  scheduled_date date [not null]
  status text [not null]
  generated_transaction_id uuid [ref: > transactions.id]
  reminder_sent_at timestamp
  posted_at timestamp
  skipped_at timestamp
  failure_reason text
  metadata json [not null]

  indexes {
    (recurring_template_id, scheduled_date) [unique]
  }
}

Table expected_spending_events {
  id uuid [pk]
  user_id uuid [not null, ref: > profiles.user_id]
  subcategory_id uuid [ref: > subcategories.id]
  category_id uuid [ref: > categories.id]
  event_kind text [not null]
  status text [not null]
  title text [not null]
  expected_amount_centavos bigint
  starts_on date [not null]
  ends_on date [not null]
  repeats_yearly boolean [not null]
  affects_forecast boolean [not null]
  affects_anomaly_suppression boolean [not null]
  notes text
  created_at timestamp [not null]
  updated_at timestamp [not null]
  metadata json [not null]
}

Table budget_strategy_configs {
  id uuid [pk]
  user_id uuid [ref: > profiles.user_id]
  strategy text [not null]
  name text [not null]
  description text
  is_system boolean [not null]
  is_active boolean [not null]
  created_at timestamp [not null]
  updated_at timestamp [not null]
  metadata json [not null]

  indexes {
    (id, user_id) [unique]
  }
}

// Note: (strategy_config_id, user_id) references budget_strategy_configs(id, user_id) ON DELETE CASCADE
Table budget_strategy_rules {
  id uuid [pk]
  user_id uuid [not null, ref: > profiles.user_id]
  strategy_config_id uuid [not null, ref: > budget_strategy_configs.id]
  allocation_scope text [not null]
  category_id uuid [not null, ref: > categories.id]
  subcategory_id uuid [ref: > subcategories.id]
  restriction_level text [not null]
  target_percent_bps integer
  min_percent_bps integer
  max_percent_bps integer
  min_amount_centavos bigint
  max_amount_centavos bigint
  priority_order integer [not null]
  is_reducible boolean [not null]
  explanation text
  metadata json [not null]

  indexes {
    (strategy_config_id, category_id) [unique]
    (strategy_config_id, subcategory_id) [unique]
  }
}

// Note: (source_recommendation_id, user_id) references budget_recommendations(id, user_id) ON DELETE SET NULL
// Note: (forecast_run_id, user_id) references forecast_runs(id, user_id) ON DELETE SET NULL
Table budgets {
  id uuid [pk]
  user_id uuid [not null, ref: > profiles.user_id]
  status text [not null]
  source text [not null]
  source_recommendation_id uuid
  forecast_run_id uuid
  strategy text
  period_kind text [not null]
  period_start date [not null]
  period_end date [not null]
  budget_period_days integer [not null]
  total_amount_centavos bigint [not null]
  starting_balance_centavos bigint
  surplus_handling text [not null]
  deficit_handling text [not null]
  allow_deficit_planning boolean [not null]
  activated_at timestamp
  closed_at timestamp
  archived_at timestamp
  deleted_at timestamp
  explanation text
  metadata json [not null]
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (id, user_id) [unique]
  }
}

Table budget_allocations {
  id uuid [pk]
  budget_id uuid [not null, ref: > budgets.id]
  allocation_scope text [not null]
  category_id uuid [not null, ref: > categories.id]
  subcategory_id uuid [ref: > subcategories.id]
  allocated_amount_centavos bigint [not null]
  rollover_amount_centavos bigint [not null]
  spent_amount_snapshot_centavos bigint
  is_protected_snapshot boolean [not null]
  priority_weight integer
  notes text
  sort_order integer [not null]
  metadata json [not null]

  indexes {
    (budget_id, category_id) [unique]
    (budget_id, subcategory_id) [unique]
  }
}

Table budget_events {
  id uuid [pk]
  budget_id uuid [not null, ref: > budgets.id]
  actor_user_id uuid [ref: > profiles.user_id]
  action text [not null]
  created_at timestamp [not null]
  notes text
  payload json [not null]
}

// Note: (budget_id, user_id) references budgets(id, user_id) ON DELETE CASCADE
Table budget_health_snapshots {
  id uuid [pk]
  budget_id uuid [not null, ref: > budgets.id]
  user_id uuid [not null, ref: > profiles.user_id]
