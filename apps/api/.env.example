# Odin API — Environment Variables
# Copy this file to .env and fill in the values.

# Supabase project URL (required)
# Found in your Supabase dashboard under Settings > API > Project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous public key (required)
# Found in your Supabase dashboard under Settings > API > anon public
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Password reset redirect URL (optional, defaults to https://odin-budgets.buzz/auth/reset)
# AUTH_REDIRECT_URL=https://odin-budgets.buzz/auth/reset

# Server port (optional, defaults to 3001)
# PORT=3001
