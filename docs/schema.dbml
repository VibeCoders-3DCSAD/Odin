// Note: (transaction_id, user_id) references transactions(id, user_id) ON DELETE SET NULL
// Note: (budget_id, user_id) references budgets(id, user_id) ON DELETE SET NULL
// Note: (debt_account_id, user_id) references debt_accounts(id, user_id) ON DELETE SET NULL
// Note: (savings_goal_id, user_id) references savings_goals(id, user_id) ON DELETE SET NULL
